<!-- Modal dialog used to create one Contact object. -->
<!-- x:Class links the XAML to AddContactWindow.xaml.cs; xmlns:System is used by ObjectDataProvider below. -->
<!-- ResizeMode, ShowInTaskbar, and WindowStyle can be changed for a standard resizable dialog. -->
<Window x:Class="Tutorial.AddContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tutorial"
        mc:Ignorable="d"
        Title="Add contact"
        Height="250"
        Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        BorderBrush="Black"
        BorderThickness="3"
        xmlns:System="clr-namespace:System;assembly=mscorlib">
  <Window.Resources>
    <!-- Builds a list of all Gender enum values for the ComboBox. -->
    <ObjectDataProvider x:Key="GenderList" MethodName="GetValues" ObjectType="{x:Type TypeName=System:Enum}" >
      <ObjectDataProvider.MethodParameters>
        <!-- The enum type can be swapped for any other enum exposed by this project. -->
        <x:Type TypeName="local:Gender" />
      </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <!-- Header and buttons size to content; the form area receives the remaining space. -->
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Label Grid.Row="0" HorizontalAlignment="Center" FontSize="24">Add new contact</Label>
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <!-- No Width specified means each column defaults to one star-sized share. -->
        <ColumnDefinition />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <!-- Equal-height rows for the five form fields. Height can also be Auto or fixed pixels. -->
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
      </Grid.RowDefinitions>
      <Label Grid.Column="0" Grid.Row="0" Content="Name"></Label>
      <Label Grid.Column="0" Grid.Row="1" Content="Surname"></Label>
      <Label Grid.Column="0" Grid.Row="2" Content="Email"></Label>
      <Label Grid.Column="0" Grid.Row="3" Content="Phone"></Label>
      <Label Grid.Column="0" Grid.Row="4">Gender</Label>
      <!-- UpdateSourceTrigger=PropertyChanged updates the Contact while the user types. LostFocus is the TextBox default. -->
      <TextBox Grid.Column="1" Grid.Row="0" Height="24" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
      <TextBox Grid.Column="1" Grid.Row="1" Height="24" Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}" />
      <TextBox Grid.Column="1" Grid.Row="2" Height="24" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
      <TextBox Grid.Column="1" Grid.Row="3" Height="24" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
      <!-- ItemsSource uses the enum values resource; SelectedItem writes the chosen enum to Contact.Gender. -->
      <ComboBox Grid.Column="1" Grid.Row="4" Height="24" ItemsSource="{Binding Source={StaticResource GenderList}}" SelectedItem="{Binding Path=Gender}" />
    </Grid>
    <!-- Horizontal layout keeps the confirm/cancel actions side by side. -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
      <!-- Click values refer to handlers in AddContactWindow.xaml.cs. -->
      <Button Width="100" Height="30" Click="AddContact">Add contact</Button>
      <Button Width="100" Height="30" Click="Cancel" Margin="15,0,0,0">Cancel</Button>
    </StackPanel>
  </Grid>
</Window>
